# PostgreSQL 연결 문자열
DATABASE_URL="postgresql://sixsound:sixsound@localhost:5432/sixsound?schema=public"

# Auth.js 세션 암호화 키 (운영 시 반드시 무작위 값으로 교체: `openssl rand -base64 32`)
AUTH_SECRET="replace-with-a-long-random-string"

# 시드로 생성할 최초 운영진 계정
ADMIN_EMAIL="admin@sixsound.kr"
ADMIN_PASSWORD="changeme1234"
ADMIN_NAME="운영진"

# 네이버 클라우드 CLOVA OCR (영수증 자동 인식)
# NCP 콘솔 → AI Services → CLOVA OCR → Domain 생성(Document/영수증)
#  → API Gateway 자동 연동 → Secret Key 발급 + Invoke URL 복사
# 비워 두면 영수증 자동 인식만 비활성화되고 장부 수기 입력은 정상 동작한다.
CLOVA_OCR_INVOKE_URL=""
CLOVA_OCR_SECRET=""
