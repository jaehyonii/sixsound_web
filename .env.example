# PostgreSQL 연결 문자열
DATABASE_URL="postgresql://sixsound:sixsound@localhost:5432/sixsound?schema=public"

# Auth.js 세션 암호화 키 (운영 시 반드시 무작위 값으로 교체: `openssl rand -base64 32`)
AUTH_SECRET="replace-with-a-long-random-string"

# 시드로 생성할 최초 운영진 계정
ADMIN_EMAIL="admin@sixsound.kr"
ADMIN_PASSWORD="changeme1234"
ADMIN_NAME="운영진"
