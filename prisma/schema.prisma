// 여섯소리(sixsound) 데이터 모델
// 영상은 sourceType/sourceRef로 "어디서 재생하느냐"를 분리해 차후 교체가 쉽도록 설계한다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 운영진 계정 (관리자 로그인)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

/// 연주회(이벤트). 한 연주회에 여러 곡 영상(Video)이 달린다.
model Concert {
  id          String   @id @default(cuid())
  title       String
  performedAt DateTime // 연주 일자
  venue       String? // 장소
  description String? // 소개
  posterUrl   String? // 포스터 이미지 경로
  videos      Video[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([performedAt])
}

/// 영상 소스 종류 (재생 추상화의 핵심)
enum VideoSourceType {
  YOUTUBE // sourceRef = YouTube video id
  FILE // sourceRef = 자체 호스팅 파일 경로 (미래)
  EXTERNAL // sourceRef = 외부 재생 URL (미래)
}

/// 개별 연주 영상
model Video {
  id           String          @id @default(cuid())
  concertId    String
  concert      Concert         @relation(fields: [concertId], references: [id], onDelete: Cascade)
  title        String // 영상 제목
  performers   String? // 연주자
  pieceTitle   String? // 곡명
  composer     String? // 작곡가
  sourceType   VideoSourceType @default(YOUTUBE)
  sourceRef    String // YouTube id / 파일 경로 / 외부 URL
  thumbnailUrl String? // 비우면 sourceType에서 자동 유도
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())

  @@index([concertId])
}

/// 공지사항 / 일정
model Notice {
  id        String    @id @default(cuid())
  title     String
  content   String
  eventDate DateTime? // 일정이 있는 공지면 날짜
  isPinned  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
}

/// 부원 (기수별)
model Member {
  id         String   @id @default(cuid())
  name       String
  generation Int // 기수
  bio        String?
  photoUrl   String?
  executives Executive[] // 이 부원이 맡은 집행부 직책들
  createdAt  DateTime @default(now())

  @@index([generation])
}

/// 집행부(기수별 임원). 직책(title)은 자유 입력, 인물은 부원(Member)에 연결한다.
/// generation = 집행부 임기 기수(부원 본인의 입부 기수와 다를 수 있음).
model Executive {
  id         String   @id @default(cuid())
  generation Int // 집행부 임기 기수
  title      String // 직책 (회장·총무 등 자유 입력)
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0) // 같은 기수 내 표시 순서 (회장=0 …)
  createdAt  DateTime @default(now())

  @@index([generation])
}

/// 동아리 소개 (단일 레코드, id = "about")
model AboutContent {
  id        String   @id @default("about")
  body      String   @default("")
  updatedAt DateTime @updatedAt
}

/// 장부 항목 종류
enum LedgerType {
  INCOME // 수입 (회비, 후원 등)
  EXPENSE // 지출
}

/// 회계 장부. 기입·수정은 운영진만, 공개 페이지에는 내역과 잔액만 노출한다.
/// receiptUrl(영수증 사진)은 관리자 전용이며 공개 페이지에서 절대 조회하지 않는다.
model LedgerEntry {
  id          String     @id @default(cuid())
  occurredAt  DateTime // 거래 일자
  type        LedgerType
  description String // 내역 (예: 동아리방 비품 구입)
  amount      Int // 금액(원). 항상 양수로 저장하고 부호는 type으로 판단한다.
  category    String? // 분류 (비품/식비/공연/회비 …) 자유 입력
  vendor      String? // 상호 (영수증에서 자동 추출)
  method      String? // 결제수단 (카드/현금/이체)
  note        String? // 비고
  receiptUrl  String? // 영수증 사진 경로 (관리자 전용)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([occurredAt])
}
